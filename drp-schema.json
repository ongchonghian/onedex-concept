      "title": "Referring Clinic Name",
      "minLength": 1
    },
    "clinic_uen": {
      "type": "string",
      "description": "Referring Clinic Unique Entity Number",
      "title": "Referring Clinic Unique Entity Number",
      "minLength": 1
    },
    "screening_dt": {
      "type": "string",
      "format": "date-time",
      "description": "Screening Date Time\n\nFormat: *YYYY-MM-DD*T*HH:MM:SS.mSmSmS*Z\n\nTimezone: Coordinated Universal Time (UTC)\n\nExample: 6 September 2022, 2:05 pm --> 2022-09-06T14:05:00.000Z\n",
      "title": "Screening Date Time",
      "minLength": 1
    },
    "screening_report_dt": {
      "type": "string",
      "format": "date-time",
      "description": "Screening Report Date Time\n\nFormat: *YYYY-MM-DD*T*HH:MM:SS.mSmSmS*Z\n\nTimezone: Coordinated Universal Time (UTC)\n\nExample: 6 September 2022, 2:05 pm --> 2022-09-06T14:05:00.000Z\n",
      "title": "Screening Report Date Time",
      "minLength": 1
    },
    "screening_report_file": {
      "type": "string",
